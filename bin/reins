#!/usr/bin/env bash
# REINS Method CLI — install, update, and manage the global REINS workflow.
# POSIX-ish bash, no Node/Python runtime required.

set -euo pipefail

REINS_HOME="${REINS_HOME:-$HOME/.reins}"
CORE_DIR="$REINS_HOME/core"
USER_DIR="$REINS_HOME/user"
AGENTS_DIR="$REINS_HOME/agents"
CONFIG="$USER_DIR/config.yaml"

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------

log()  { printf '%s\n' "$*"; }
err()  { printf 'Error: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
capitalize() { printf '%s%s' "$(printf '%s' "${1:0:1}" | tr '[:lower:]' '[:upper:]')" "${1:1}"; }

print_banner() {
  local horse=$'\033[32m' rtxt=$'\033[92m' muted=$'\033[2;32m'
  local check=$'\033[92m' text=$'\033[32m' reset=$'\033[0m'

  printf '%s%s%s%s%s\n' "$horse" '      ,~~_              ' "$rtxt" '____  ___________   _______' "$reset"
  printf '%s%s%s%s%s\n' "$horse" '      |/\ =_ _ ~       ' "$rtxt" '/ __ \/ ____/  _/ | / / ___/' "$reset"
  printf '%s%s%s%s%s\n' "$horse" '       _( )_( )\~~    ' "$rtxt" '/ /_/ / __/  / //  |/ /\__ \' "$reset"
  printf '%s%s%s%s%s\n' "$horse" '       \,\  _|\ \~~~ ' "$rtxt" '/ _, _/ /____/ // /|  /___/ /' "$reset"
  printf '%s%s%s%s%s\n' "$horse" '          \`   \    ' "$rtxt" '/_/ |_/_____/___/_/ |_//____/' "$reset"
  printf '%s%s%s\n' "$horse" '          `    `' "$reset"
  printf '\n'
  printf '%s  Structured AI Pair Programming Method%s\n' "$muted" "$reset"
  printf '%s  ──────────────────────────────────────────────────%s\n' "$muted" "$reset"
  printf '  Agent-agnostic · Stack-agnostic · Globally installed\n'
  printf '\n'

  printf '%s✓%s REINS installed to ~/.reins/%s\n' "$check" "$text" "$reset"

  local bridge_ok=0
  while IFS= read -r _a; do
    [ -n "$_a" ] || continue
    local _entry
    if _entry="$(agent_bridge_target "$_a" 2>/dev/null)"; then
      local _bridge="${_entry%%:*}"
      [ -f "$_bridge" ] && bridge_ok=1 && break
    fi
  done < <(config_get_agents)
  if [ "$bridge_ok" -eq 1 ]; then
    printf '%s✓%s Agent bridge configured%s\n' "$check" "$text" "$reset"
  fi

  local skill_count=0
  if [ -d "$CORE_DIR/skills" ]; then
    skill_count="$(find "$CORE_DIR/skills" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
  fi
  printf '%s✓%s %s core skills registered%s\n' "$check" "$text" "$skill_count" "$reset"
  printf '\n'
}

config_get() {
  # config_get <key> -> prints scalar value for "key: value" line, empty if absent
  [ -f "$CONFIG" ] || return 0
  grep -E "^${1}:" "$CONFIG" 2>/dev/null | head -n1 | sed -E "s/^${1}:[[:space:]]*//"
}

config_set() {
  # config_set <key> <value> -> upsert "key: value" line
  local key="$1" value="$2"
  mkdir -p "$USER_DIR"
  touch "$CONFIG"
  if grep -qE "^${key}:" "$CONFIG"; then
    sed -i.bak -E "s|^${key}:.*|${key}: ${value}|" "$CONFIG" && rm -f "${CONFIG}.bak"
  else
    printf '%s: %s\n' "$key" "$value" >> "$CONFIG"
  fi
}

config_adapters() {
  # prints one adapter name per line, from the "adapters:" YAML list
  [ -f "$CONFIG" ] || return 0
  awk '/^adapters:/{found=1; next} /^[a-zA-Z]/{found=0} found && /^[[:space:]]*-/{gsub(/^[[:space:]]*-[[:space:]]*/,""); print}' "$CONFIG"
}

config_get_agents() {
  # prints one agent id per line; reads "agents:" list, falls back to "agent:" scalar
  [ -f "$CONFIG" ] || return 0
  if grep -qE "^agents:" "$CONFIG" 2>/dev/null; then
    awk '/^agents:/{found=1; next} /^[a-zA-Z]/{found=0} found && /^[[:space:]]*-/{gsub(/^[[:space:]]*-[[:space:]]*/,""); print}' "$CONFIG"
  else
    local a
    a="$(config_get agent)"
    [ -n "$a" ] && printf '%s\n' "$a"
  fi
}

config_set_agents() {
  # config_set_agents <agent1> [agent2 ...] -> write agents YAML list, removing old agent/agents entries
  [ "$#" -gt 0 ] || return 0
  mkdir -p "$USER_DIR"
  touch "$CONFIG"
  awk '
    /^agents:/ { skip=1; next }
    /^agent:/  { next }
    /^[a-zA-Z_]/ { skip=0 }
    !skip { print }
  ' "$CONFIG" > "$CONFIG.tmp" && mv "$CONFIG.tmp" "$CONFIG"
  printf 'agents:\n' >> "$CONFIG"
  local a
  for a in "$@"; do
    printf '  - %s\n' "$a" >> "$CONFIG"
  done
}

download_and_extract() {
  # download_and_extract <source-url> -> prints path to extracted dir; caller must rm -rf dirname
  local source_url="$1"
  local tarball_url="${source_url}/archive/refs/heads/main.tar.gz"
  local tmp_tar="/tmp/reins-dl-$$.tar.gz"
  local tmp_parent="/tmp/reins-ex-$$"
  mkdir -p "$tmp_parent"
  if ! curl -fsSL "$tarball_url" -o "$tmp_tar" 2>/dev/null; then
    rm -f "$tmp_tar"; rm -rf "$tmp_parent"
    die "Failed to download REINS from $tarball_url — check your internet connection"
  fi
  if ! tar -xzf "$tmp_tar" -C "$tmp_parent" 2>/dev/null; then
    rm -f "$tmp_tar"; rm -rf "$tmp_parent"
    die "Failed to extract REINS archive"
  fi
  rm -f "$tmp_tar"
  printf '%s\n' "$tmp_parent/reins-method-main"
}

install_core_files() {
  # install_core_files <src-dir> — overwrites core, bin, tools; never touches user/
  local src="$1"
  # Remove git metadata and dev-only files from older git-clone installs
  rm -rf "$REINS_HOME/.git" "$REINS_HOME/.github" "$CORE_DIR" \
         "$REINS_HOME/bin" "$REINS_HOME/tools"
  local _dev
  for _dev in ADAPTERS.md HISTORIC_MODE.md MIGRATION.md README.md SKILLS.md \
               install.sh LICENSE .gitignore package-lock.json; do
    rm -f "$REINS_HOME/$_dev"
  done
  mkdir -p "$REINS_HOME/agents"
  cp -r "$src/core"  "$REINS_HOME/core"
  cp -r "$src/bin"   "$REINS_HOME/bin"
  cp -r "$src/tools" "$REINS_HOME/tools"
  cp    "$src/package.json" "$REINS_HOME/package.json"
  [ -f "$src/VERSION" ] && cp "$src/VERSION" "$REINS_HOME/VERSION" || true
  chmod +x "$REINS_HOME/bin/reins" 2>/dev/null || true
}

ensure_managed_block() {
  # ensure_managed_block <target-file> <content-line>
  # Inserts/replaces a REINS-managed block in <target-file> without touching
  # the rest of the file's content.
  local target="$1" content="$2"
  local begin="<!-- REINS:BEGIN -->" end="<!-- REINS:END -->"
  mkdir -p "$(dirname "$target")"
  touch "$target"
  if grep -qF "$begin" "$target"; then
    awk -v b="$begin" -v e="$end" -v c="$content" '
      $0 == b {print; print c; skip=1; next}
      $0 == e {print; skip=0; next}
      skip {next}
      {print}
    ' "$target" > "$target.tmp" && mv "$target.tmp" "$target"
  else
    {
      printf '\n%s\n' "$begin"
      printf '%s\n' "$content"
      printf '%s\n' "$end"
    } >> "$target"
  fi
}

ensure_managed_block_from_file() {
  # ensure_managed_block_from_file <target-file> <source-file>
  # Like ensure_managed_block but reads content from a file — safe for multiline.
  local target="$1" src="$2"
  local begin="<!-- REINS:BEGIN -->" end="<!-- REINS:END -->"
  mkdir -p "$(dirname "$target")"
  touch "$target"
  local tmp
  tmp="$(mktemp)"
  if grep -qF "$begin" "$target"; then
    awk -v b="$begin" -v e="$end" -v f="$src" '
      $0 == b { print; while ((getline line < f) > 0) print line; close(f); skip=1; next }
      $0 == e { skip=0; print; next }
      skip { next }
      { print }
    ' "$target" > "$tmp" && mv "$tmp" "$target"
  else
    {
      printf '\n%s\n' "$begin"
      cat "$src"
      printf '%s\n' "$end"
    } >> "$target"
  fi
  rm -f "$tmp"
}

remove_managed_block() {
  # remove_managed_block <target-file>
  # Strips the REINS-managed block (and the blank line preceding it) from
  # <target-file>, if present. No-op if the file or block doesn't exist.
  local target="$1"
  local begin="<!-- REINS:BEGIN -->" end="<!-- REINS:END -->"
  [ -f "$target" ] || return 0
  grep -qF "$begin" "$target" || return 0
  awk -v b="$begin" -v e="$end" '
    $0 == b {skip=1; if (out ~ /\n\n$/) { sub(/\n$/, "", out) }; next}
    $0 == e {skip=0; next}
    skip {next}
    {out = out $0 "\n"}
    END {printf "%s", out}
  ' "$target" > "$target.tmp" && mv "$target.tmp" "$target"
}

agent_bridge_target() {
  # agent_bridge_target <agent> -> prints "<bridge-file>:<native-target>:<import-syntax>"
  case "$1" in
    claude-code) echo "$AGENTS_DIR/CLAUDE.md:$HOME/.claude/CLAUDE.md:import" ;;
    gemini)      echo "$AGENTS_DIR/GEMINI.md:$HOME/.gemini/GEMINI.md:import" ;;
    copilot)     echo "$AGENTS_DIR/copilot-instructions.md:$HOME/.copilot/instructions.md:inline" ;;
    codex)       echo "$AGENTS_DIR/AGENTS.md:$HOME/.codex/AGENTS.md:inline" ;;
    aider|opencode|other)
                 echo "$AGENTS_DIR/AGENTS.md:$HOME/AGENTS.md:inline" ;;
    *) return 1 ;;
  esac
}

wire_block() {
  # wire_block <bridge-file> <native-target> <import|inline>
  # import: single @-import line — agent runtime resolves the file
  # inline: embeds full bridge content — for agents that don't support @-imports
  local bridge="$1" native="$2" syntax="$3"
  case "$syntax" in
    import) ensure_managed_block "$native" "@${bridge}" ;;
    inline) ensure_managed_block_from_file "$native" "$bridge" ;;
  esac
}

wire_all_agents() {
  # Wires the REINS managed block into the native config of each agent the user
  # selected during install (config_get_agents). Only configured agents are wired.
  local wired=()
  while IFS= read -r _agent; do
    [ -n "$_agent" ] || continue
    local _entry
    _entry="$(agent_bridge_target "$_agent" 2>/dev/null)" || continue
    local _bridge="${_entry%%:*}" _rest="${_entry#*:}"
    local _native="${_rest%%:*}" _syntax="${_rest##*:}"
    local _label
    case "$_agent" in
      claude-code) _label="Claude Code" ;;
      gemini)      _label="Gemini CLI" ;;
      copilot)     _label="GitHub Copilot CLI" ;;
      codex)       _label="Codex CLI" ;;
      aider)       _label="Aider" ;;
      opencode)    _label="OpenCode / Cursor" ;;
      *)           _label="Other" ;;
    esac
    wire_block "$_bridge" "$_native" "$_syntax"
    wired+=("$_label -> $_native")
  done < <(config_get_agents)

  local w
  for w in "${wired[@]}"; do
    log "Wired: $w"
  done
}

unwire_all_agents() {
  # Removes the REINS managed block from every native config it may have been
  # wired into (no-op for files without a managed block).
  local t
  for t in "$HOME/.claude/CLAUDE.md" "$HOME/.gemini/GEMINI.md" \
           "$HOME/.copilot/instructions.md" "$HOME/.codex/AGENTS.md" \
           "$HOME/AGENTS.md"; do
    if [ -f "$t" ] && grep -qF "REINS:BEGIN" "$t" 2>/dev/null; then
      remove_managed_block "$t"
      log "Removed REINS block from $t"
    fi
  done
}

collect_skills() {
  # prints "<skill-dir>\t<reins-managed-name>" for every SKILL.md found under
  # core/skills, user/skills, and active adapters' skills/
  #
  # Every registered name carries the "reins-" prefix exactly once. Skill
  # directories that already start with "reins-" (the convention for core/user
  # skills) are used as-is; older, unprefixed directory names still get
  # "reins-" prepended for backwards compatibility.
  local d name
  for d in "$CORE_DIR"/skills/*/; do
    [ -f "${d}SKILL.md" ] || continue
    name="$(basename "$d")"
    case "$name" in
      reins-*) printf '%s\t%s\n' "${d%/}" "$name" ;;
      *) printf '%s\treins-%s\n' "${d%/}" "$name" ;;
    esac
  done
  for d in "$USER_DIR"/skills/*/; do
    [ -f "${d}SKILL.md" ] || continue
    name="$(basename "$d")"
    case "$name" in
      reins-*) printf '%s\t%s\n' "${d%/}" "$name" ;;
      *) printf '%s\treins-%s\n' "${d%/}" "$name" ;;
    esac
  done
  while IFS= read -r adapter; do
    [ -n "$adapter" ] || continue
    for d in "$USER_DIR/adapters/$adapter/skills"/*/; do
      [ -f "${d}SKILL.md" ] || continue
      name="$(basename "$d")"
      case "$name" in
        reins-*) name="${name#reins-}" ;;
      esac
      printf '%s\treins-%s-%s\n' "${d%/}" "$adapter" "$name"
    done
  done < <(config_adapters)
}

skill_frontmatter() {
  # skill_frontmatter <SKILL.md> <key> -> prints a one-line value for "key: value"
  # or "key: >" (folded scalar) frontmatter fields, empty if absent
  local file="$1" key="$2"
  awk -v k="$key" '
    /^---$/ { fm++; next }
    fm != 1 { next }
    $0 ~ "^"k":" {
      line=$0
      sub("^"k":[[:space:]]*", "", line)
      sub(/^>[[:space:]]*/, "", line)
      if (line != "") { print line; found=1; exit }
      found=1; next
    }
    found && /^[[:space:]]+[^[:space:]]/ {
      line=$0
      sub(/^[[:space:]]+/, "", line)
      print line
      exit
    }
    found { exit }
  ' "$file"
}

cleanup_skill_links() {
  # cleanup_skill_links <skills-dir>
  local skills_dir="$1"
  [ -d "$skills_dir" ] || return 0
  find "$skills_dir" -maxdepth 1 -type l -name 'reins-*' -exec rm -f {} +
}

cleanup_claude_skill_links() { cleanup_skill_links "$HOME/.claude/skills"; }

_sync_skill_symlinks() {
  # _sync_skill_symlinks <skills-dir> — refreshes reins-* symlinks in the given dir
  local skills_dir="$1"
  mkdir -p "$skills_dir"
  cleanup_skill_links "$skills_dir"
  while IFS=$'\t' read -r dir reins_name; do
    [ -n "$dir" ] || continue
    ln -sf "$dir" "$skills_dir/$reins_name"
  done < <(collect_skills)
}

sync_skills() {
  # Claude Code — always, if ~/.claude/ exists
  if [ -d "$HOME/.claude" ]; then
    _sync_skill_symlinks "$HOME/.claude/skills"
  fi
  # GitHub Copilot CLI — skills/ dir in ~/.copilot/
  if config_get_agents | grep -qx "copilot"; then
    _sync_skill_symlinks "$HOME/.copilot/skills"
  fi
  # Gemini CLI — skills/ dir in ~/.gemini/ (if installed)
  if config_get_agents | grep -qx "gemini" && [ -d "$HOME/.gemini" ]; then
    _sync_skill_symlinks "$HOME/.gemini/skills"
  fi
  # Codex CLI — skills/ dir in ~/.codex/
  if config_get_agents | grep -qx "codex"; then
    _sync_skill_symlinks "$HOME/.codex/skills"
  fi
}

generate_bridges() {
  # Regenerate ~/.reins/agents/*.md from core + user content, then wire native configs.
  mkdir -p "$AGENTS_DIR"
  local agents_configured
  agents_configured="$(config_get_agents)"
  [ -n "$agents_configured" ] || { err "no agents configured — run 'reins install'"; return 1; }

  local active_adapters
  active_adapters="$(config_adapters | tr '\n' ' ')"
  local historic
  historic="$(config_get historic_mode)"
  local language doc_language
  language="$(config_get language)"
  doc_language="$(config_get doc_language)"

  local skills_md=""
  while IFS=$'\t' read -r dir reins_name; do
    [ -n "$dir" ] || continue
    local sname sdesc
    sname="$(skill_frontmatter "$dir/SKILL.md" name)"
    sdesc="$(skill_frontmatter "$dir/SKILL.md" description)"
    skills_md="${skills_md}- **${sname:-$reins_name}** (\`$dir\`): ${sdesc:-(no description)}
"
  done < <(collect_skills)

  local body
  body=$(cat <<EOF
# REINS Method — Agent Bridge

This file is generated by \`reins update\` / \`reins install\`. Do not edit by hand —
edit \`~/.reins/user/config.yaml\` and re-run \`reins update\` instead.

## Always read first
- @${CORE_DIR}/workflow/1_orchestrator.md

## User standards
- @${USER_DIR}/standards/company.md
- @${USER_DIR}/standards/personal.md

## Active adapters
${active_adapters:-(none configured — generic conventions only)}

## Historic mode
${historic:-off}

## Language
- Interaction language: $(capitalize "${language:-English}")
- Documentation language: $(capitalize "${doc_language:-English}")

## Available skills
On-demand only — never load proactively (see \`1_orchestrator.md\` §5).
${skills_md:-(none)}
EOF
)
  printf '%s\n' "$body" > "$AGENTS_DIR/CLAUDE.md"
  printf '%s\n' "$body" > "$AGENTS_DIR/GEMINI.md"
  printf '%s\n' "$body" > "$AGENTS_DIR/AGENTS.md"
  printf '%s\n' "$body" > "$AGENTS_DIR/copilot-instructions.md"

  wire_all_agents
  sync_skills

  log "Bridge files regenerated in $AGENTS_DIR"
}

# ---------------------------------------------------------------------------
# commands
# ---------------------------------------------------------------------------

cmd_install() {
  print_banner
  local non_interactive=0
  local arg_agents=() arg_standards="" arg_historic="" arg_adapter=""
  local arg_language="" arg_doc_language="" arg_from_package=""
  for arg in "$@"; do
    case "$arg" in
      --non-interactive)  non_interactive=1 ;;
      --agent=*)          arg_agents+=("${arg#--agent=}") ;;
      --standards=*)      arg_standards="${arg#--standards=}" ;;
      --historic=*)       arg_historic="${arg#--historic=}" ;;
      --adapter=*)        arg_adapter="${arg#--adapter=}" ;;
      --language=*)       arg_language="${arg#--language=}" ;;
      --doc-language=*)   arg_doc_language="${arg#--doc-language=}" ;;
      --from-package=*)   arg_from_package="${arg#--from-package=}" ;;
    esac
  done

  # --- Core file setup (runs once; skipped on re-configure) ---
  if [ -n "$arg_from_package" ]; then
    install_core_files "$arg_from_package"
  elif [ ! -d "$CORE_DIR" ]; then
    local reins_source="https://github.com/gustavodiasp/reins-method"
    log "Downloading REINS Method..."
    local _extracted
    _extracted="$(download_and_extract "$reins_source")"
    install_core_files "$_extracted"
    rm -rf "$(dirname "$_extracted")"
  fi

  # When run via `curl | bash`, stdin is the piped script, not a terminal, so
  # `read -p` below would fail instantly. Re-attach stdin to the controlling
  # terminal if one is available so the wizard can still prompt interactively.
  if [ "$non_interactive" -eq 0 ] && [ ! -t 0 ] && [ -e /dev/tty ]; then
    exec < /dev/tty
  fi

  log "Welcome to REINS Method"
  log ""

  if [ -f "$CONFIG" ] && [ "$non_interactive" -eq 0 ]; then
    read -r -p "REINS is already configured at $REINS_HOME. Re-run the wizard? [y/N] " yn
    case "$yn" in [yY]*) ;; *) log "Aborted."; return 0 ;; esac
  fi

  mkdir -p "$USER_DIR"/{standards,adapters,skills,projects,historic}

  local selected_agents=()
  if [ "$non_interactive" -eq 1 ]; then
    if [ "${#arg_agents[@]}" -gt 0 ]; then
      selected_agents=("${arg_agents[@]}")
    else
      selected_agents=("other")
    fi
  else
    log "? Which AI coding agents do you use?"
    log "  (REINS wires every agent it detects on this machine automatically.)"
    log "  1) Claude Code"
    log "  2) GitHub Copilot CLI"
    log "  3) Codex CLI"
    log "  4) Gemini CLI"
    log "  5) Aider"
    log "  6) OpenCode / Cursor / Other"
    read -r -p "Numbers separated by spaces [1]: " agent_choices
    agent_choices="${agent_choices:-1}"
    IFS=' ,' read -ra agent_nums <<< "$agent_choices"
    for num in "${agent_nums[@]}"; do
      case "$num" in
        1) selected_agents+=("claude-code") ;;
        2) selected_agents+=("copilot") ;;
        3) selected_agents+=("codex") ;;
        4) selected_agents+=("gemini") ;;
        5) selected_agents+=("aider") ;;
        6) selected_agents+=("other") ;;
      esac
    done
    [ "${#selected_agents[@]}" -eq 0 ] && selected_agents=("other")
  fi
  config_set_agents "${selected_agents[@]}"

  local language doc_language
  if [ "$non_interactive" -eq 1 ]; then
    language="${arg_language:-English}"
    doc_language="${arg_doc_language:-English}"
  else
    read -r -p "? Language to interact in (agent replies, skill/persona output)? [English] " language
    language="${language:-English}"
    read -r -p "? Language for documentation (code comments, docstrings, READMEs, etc.)? [English] " doc_language
    doc_language="${doc_language:-English}"
  fi
  config_set language "$language"
  config_set doc_language "$doc_language"

  touch "$USER_DIR/standards/company.md" "$USER_DIR/standards/personal.md"
  if [ ! -s "$USER_DIR/standards/company.md" ]; then
    cat > "$USER_DIR/standards/company.md" <<'EOF'
---
scope: always
precedence: 1 # floor — non-negotiable
---

# Company / Project Standards

Fill this in with the non-negotiable conventions for your company or project.
This file is read by the orchestrator on every session.
EOF
  fi
  if [ ! -s "$USER_DIR/standards/personal.md" ]; then
    cat > "$USER_DIR/standards/personal.md" <<'EOF'
---
scope: always
precedence: 2 # personal style — must never conflict with company.md
---

# Personal Standards

Fill this in with your personal style preferences on top of company.md.
If anything here conflicts with company.md, the orchestrator will stop and ask.
EOF
  fi
  if [ "$non_interactive" -eq 1 ]; then
    # The Node wizard (npx reins-method install) handles opening an editor
    # for company.md itself, after this script returns — it has the TTY.
    :
  else
    read -r -p "? Do you have company code standards to configure? [y/N] " yn
    case "$yn" in
      [yY]*)
        "${EDITOR:-vi}" "$USER_DIR/standards/company.md"
        ;;
    esac
  fi

  if [ "$non_interactive" -eq 1 ]; then
    case "$arg_historic" in
      on) cmd_historic on --quiet ;;
      *) config_set historic_mode off ;;
    esac
  else
    read -r -p "? Do you want to enable Historic Mode (performance tracking)? [y/N] " yn
    case "$yn" in
      [yY]*) cmd_historic on --quiet ;;
      *) config_set historic_mode off ;;
    esac
  fi

  local adapter_path
  if [ "$non_interactive" -eq 1 ]; then
    adapter_path="$arg_adapter"
  else
    read -r -p "? Install an adapter pack now? Path to local pack (or leave empty to skip): " adapter_path
  fi
  if [ -n "$adapter_path" ] && [ -d "$adapter_path" ]; then
    local adapter_name
    adapter_name="$(basename "$adapter_path")"
    mkdir -p "$USER_DIR/adapters"
    cp -R "$adapter_path" "$USER_DIR/adapters/$adapter_name"
    if grep -qE "^adapters:" "$CONFIG" 2>/dev/null; then
      printf '  - %s\n' "$adapter_name" >> "$CONFIG"
    else
      printf 'adapters:\n  - %s\n' "$adapter_name" >> "$CONFIG"
    fi
    log "Adapter '$adapter_name' installed."
  fi

  local _inst_ver
  _inst_ver="$(cat "$REINS_HOME/VERSION" 2>/dev/null)" \
    || _inst_ver="$(grep -m1 '"version"' "$REINS_HOME/package.json" 2>/dev/null \
         | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  config_set installed_version "${_inst_ver:-unknown}"
  config_set reins_source "https://github.com/gustavodiasp/reins-method"
  config_set installed_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if command -v npm >/dev/null 2>&1 && [ -f "$REINS_HOME/package.json" ]; then
    npm install --prefix "$REINS_HOME" --silent --omit=dev 2>/dev/null || true
  fi

  generate_bridges

  # Make `reins` available on PATH
  local target_bin="/usr/local/bin/reins"
  if [ -w "$(dirname "$target_bin")" ] 2>/dev/null; then
    ln -sf "$REINS_HOME/bin/reins" "$target_bin" 2>/dev/null || true
  fi
  if [ ! -x "$target_bin" ]; then
    for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
      [ -f "$rc" ] || continue
      grep -qF "$REINS_HOME/bin" "$rc" 2>/dev/null || \
        printf '\nexport PATH="%s/bin:$PATH"\n' "$REINS_HOME" >> "$rc"
    done
  fi

  log ""
  log "REINS Method installed to $REINS_HOME"
  log "Run: source ~/.zshrc (or restart your terminal) to activate the 'reins' command"
  log ""
  log "Optional companion tools (see README.md 'Companion tools'):"
  log "  - headroom: token-efficient context compression (pip install \"headroom-ai[all]\")"
  log "  - graphify: codebase knowledge graph for richer architecture context (pip install graphifyy)"
  log ""
  log "Getting started: reins status"
}

cmd_update() {
  [ -f "$CONFIG" ] || die "No user config found. Run 'reins install' first."

  local reins_source old_version
  reins_source="$(config_get reins_source 2>/dev/null)"
  reins_source="${reins_source:-https://github.com/gustavodiasp/reins-method}"
  old_version="$(config_get installed_version 2>/dev/null)"

  log "Downloading update..."
  local _extracted
  _extracted="$(download_and_extract "$reins_source")"

  local new_version
  new_version="$(cat "$_extracted/VERSION" 2>/dev/null)" \
    || new_version="$(grep -m1 '"version"' "$_extracted/package.json" 2>/dev/null \
         | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  new_version="${new_version:-unknown}"

  install_core_files "$_extracted"
  rm -rf "$(dirname "$_extracted")"

  if command -v npm >/dev/null 2>&1 && [ -f "$REINS_HOME/package.json" ]; then
    npm install --prefix "$REINS_HOME" --silent --omit=dev 2>/dev/null || true
  fi

  config_set installed_version "$new_version"
  config_set updated_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  sync_skills
  generate_bridges

  print_banner
  if [ "${old_version:-}" = "$new_version" ]; then
    log "Already up to date (v${new_version})."
  else
    log "✓ REINS updated${old_version:+ from v$old_version} to v${new_version}"
  fi
  log "~/.reins/user/ was not touched."
}

cmd_new_adapter() {
  print_banner
  local name="${1:-}"
  [ -n "$name" ] || die "usage: reins new-adapter <name>"
  local dir="$USER_DIR/adapters/$name"
  [ -e "$dir" ] && die "$dir already exists"
  mkdir -p "$dir"/{standards,workflow,skills}
  cat > "$dir/ADAPTER.md" <<EOF
---
name: $name
stacks: []   # e.g. [ruby], [node], [python] — see core/workflow/1_orchestrator.md §2
author: $(whoami)
version: 0.1.0
description: >
  Describe what this adapter is for and what conventions/skills it adds.
---
EOF
  cat > "$dir/standards/floor.md" <<'EOF'
---
scope: always
precedence: 1 # floor — non-negotiable
---

# Standards — Floor

Non-negotiable conventions for this stack.
EOF
  log "Adapter scaffolded at $dir"
  log "Edit ADAPTER.md (set 'stacks'), then standards/floor.md."
  if grep -qE "^adapters:" "$CONFIG" 2>/dev/null; then
    printf '  - %s\n' "$name" >> "$CONFIG"
  else
    printf 'adapters:\n  - %s\n' "$name" >> "$CONFIG"
  fi
  generate_bridges
}

cmd_new_skill() {
  print_banner
  local name="${1:-}"
  [ -n "$name" ] || die "usage: reins new-skill <name>"
  local dir="$USER_DIR/skills/$name"
  [ -e "$dir" ] && die "$dir already exists"
  mkdir -p "$dir"
  cat > "$dir/SKILL.md" <<EOF
---
name: $name
description: TODO — what this skill does and when to use it.
---

# $name

## Trigger
TODO

## Context
TODO

## Steps
TODO

## Output
TODO
EOF
  log "Skill scaffolded at $dir/SKILL.md — fill it in (see core/templates/skill.md)."
  generate_bridges >/dev/null
}

cmd_sync() {
  sync_skills
  generate_bridges
  print_banner
}

cmd_graphify() {
  local project_root
  if ! project_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    project_root="$(pwd)"
  fi

  local slug
  slug="$(basename "$project_root")"

  local dest="$USER_DIR/projects/$slug/graphify-out"

  if ! command -v graphify >/dev/null 2>&1; then
    err "graphify is not installed."
    err "Install it with: pip install graphifyy && graphify install"
    return 1
  fi

  log "Project: $slug ($project_root)"
  log "Output:  $dest"
  log ""

  (cd "$project_root" && graphify .)

  local tmp_out="$project_root/graphify-out"
  if [ -d "$tmp_out" ]; then
    mkdir -p "$(dirname "$dest")"
    rm -rf "$dest"
    mv "$tmp_out" "$dest"
    log ""
    log "Done. GRAPH_REPORT.md stored at $dest/GRAPH_REPORT.md"
    log "REINS's orchestrator will pick it up automatically at session start."
  else
    err "graphify did not produce graphify-out/ — check for errors above."
    return 1
  fi
}

cmd_agents() {
  # Delegate to Node/clack UI if available; bash wizard otherwise.
  local cli="$REINS_HOME/tools/installer/cli.js"
  if command -v node >/dev/null 2>&1 && [ -f "$cli" ] && [ -d "$REINS_HOME/node_modules" ]; then
    node "$cli" agents
    return
  fi
  # bash fallback (no Node)
  print_banner
  if [ ! -t 0 ] && [ -e /dev/tty ]; then exec < /dev/tty; fi
  local current
  current="$(config_get_agents | tr '\n' ' ' | sed 's/ $//')"
  [ -n "$current" ] && log "Current agents: $current"
  log ""
  log "? Which AI coding agents do you use?"
  log "  1) Claude Code"
  log "  2) GitHub Copilot CLI"
  log "  3) Codex CLI"
  log "  4) Gemini CLI"
  log "  5) Aider"
  log "  6) OpenCode / Cursor / Other"
  read -r -p "Numbers separated by spaces [1]: " agent_choices
  agent_choices="${agent_choices:-1}"
  IFS=' ,' read -ra agent_nums <<< "$agent_choices"
  local selected_agents=()
  for num in "${agent_nums[@]}"; do
    case "$num" in
      1) selected_agents+=("claude-code") ;;
      2) selected_agents+=("copilot") ;;
      3) selected_agents+=("codex") ;;
      4) selected_agents+=("gemini") ;;
      5) selected_agents+=("aider") ;;
      6) selected_agents+=("other") ;;
    esac
  done
  [ "${#selected_agents[@]}" -eq 0 ] && selected_agents=("other")
  config_set_agents "${selected_agents[@]}"
  generate_bridges
  log "Agent selection updated."
}

cmd_agents_set() {
  # Internal: called by cli.js after user confirms selection.
  local selected_agents=()
  for arg in "$@"; do
    case "$arg" in
      --agent=*) selected_agents+=("${arg#--agent=}") ;;
    esac
  done
  [ "${#selected_agents[@]}" -gt 0 ] || { err "no agents specified"; return 1; }

  # Collect native targets of the new selection (to avoid unwiring shared files)
  local new_natives=""
  local _a _e _n
  for _a in "${selected_agents[@]}"; do
    _e="$(agent_bridge_target "$_a" 2>/dev/null)" || continue
    _n="${_e#*:}"; _n="${_n%%:*}"
    new_natives="${new_natives}${_n}"$'\n'
  done

  # Unwire agents being removed, skip if their native file is still needed
  while IFS= read -r old_agent; do
    [ -n "$old_agent" ] || continue
    _e="$(agent_bridge_target "$old_agent" 2>/dev/null)" || continue
    _n="${_e#*:}"; _n="${_n%%:*}"
    printf '%s' "$new_natives" | grep -qxF "$_n" && continue
    if [ -f "$_n" ] && grep -qF "REINS:BEGIN" "$_n" 2>/dev/null; then
      remove_managed_block "$_n"
      local _label
      case "$old_agent" in
        claude-code) _label="Claude Code" ;;
        gemini)      _label="Gemini CLI" ;;
        copilot)     _label="GitHub Copilot CLI" ;;
        codex)       _label="Codex CLI" ;;
        aider)       _label="Aider" ;;
        opencode)    _label="OpenCode / Cursor" ;;
        *)           _label="Other" ;;
      esac
      log "Unwired: $_label ($_n)"
    fi
  done < <(config_get_agents)

  config_set_agents "${selected_agents[@]}"
  generate_bridges
}

cmd_edit() {
  local target="${1:-}"
  local editor="${EDITOR:-code}"
  case "$target" in
    standards) "$editor" "$USER_DIR/standards/" ;;
    adapters)  "$editor" "$USER_DIR/adapters/" ;;
    skills)    "$editor" "$USER_DIR/skills/" ;;
    historic)  "$editor" "$USER_DIR/historic/" ;;
    config)    "$editor" "$CONFIG" ;;
    "")
      log "Usage: reins edit <target>"
      log "Targets:"
      log "  standards   Your company and personal code standards"
      log "  adapters    Your adapter packs"
      log "  skills      Your custom skills"
      log "  historic    Your monthly historic records"
      log "  config      Your REINS configuration"
      return 0
      ;;
    *) err "unknown target '$target' — run 'reins edit' to see available targets"; return 1 ;;
  esac
  case "$target" in
    standards|config)
      log "Tip: run 'reins sync' after editing to refresh your agent bridges." ;;
  esac
}

cmd_link_agents() {
  print_banner
  # Wire newly-installed AI agents into the existing bridge files without a
  # full bridge regeneration — handy after installing a new agent on this
  # machine (e.g. you set up Gemini CLI after running `reins install`).
  [ -d "$AGENTS_DIR" ] && [ -n "$(ls -A "$AGENTS_DIR" 2>/dev/null)" ] || { err "no bridge files yet — run 'reins update' or 'reins sync' first"; return 1; }
  wire_all_agents
  sync_skills
  log "Done."
}

cmd_historic() {
  [ "${2:-}" = "--quiet" ] || print_banner
  local mode="${1:-}"
  case "$mode" in
    on)
      mkdir -p "$USER_DIR/historic"
      config_set historic_mode on
      local month_file="$USER_DIR/historic/$(date +%Y-%m).md"
      if [ ! -f "$month_file" ]; then
        cp "$CORE_DIR/evaluation/templates/monthly.md" "$month_file"
        [ "${2:-}" = "--quiet" ] || log "Created $month_file — fill in this period's priorities."
      fi
      [ "${2:-}" = "--quiet" ] || log "Historic mode: on"
      ;;
    off)
      config_set historic_mode off
      log "Historic mode: off (data preserved at $USER_DIR/historic/)"
      ;;
    *) die "usage: reins historic on|off" ;;
  esac
  generate_bridges >/dev/null
}

cmd_status() {
  print_banner
  log "REINS_HOME: $REINS_HOME"
  local _status_ver _status_src
  _status_ver="$(config_get installed_version 2>/dev/null)"
  if [ -z "$_status_ver" ] && [ -f "$REINS_HOME/package.json" ]; then
    _status_ver="$(grep -m1 '"version"' "$REINS_HOME/package.json" \
      | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  fi
  [ -n "$_status_ver" ] && log "Version:  $_status_ver"
  _status_src="$(config_get reins_source 2>/dev/null)"
  [ -n "$_status_src" ] && log "Source:   $_status_src"
  local agents_list
  agents_list="$(config_get_agents | tr '\n' ' ' | sed 's/ $//')"
  log "Agents: ${agents_list:-not configured}"
  log "Historic mode: $(config_get historic_mode || echo 'off')"
  log "Interaction language: $(capitalize "$(config_get language || echo 'English')")"
  log "Documentation language: $(capitalize "$(config_get doc_language || echo 'English')")"
  local adapters
  adapters="$(config_adapters | tr '\n' ' ')"
  log "Adapters: ${adapters:-none}"

  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    local slug
    slug="$(basename "$(git rev-parse --show-toplevel)")"
    local ctx_dir="$USER_DIR/projects/$slug/contexts"
    if [ -d "$ctx_dir" ]; then
      local active
      active="$(grep -lE '^status:[[:space:]]*active' "$ctx_dir"/*.md 2>/dev/null || true)"
      if [ -n "$active" ]; then
        log "Active context (this project): $(basename "$active")"
      else
        log "Active context (this project): none"
      fi
    fi
  fi
}

cmd_doctor() {
  print_banner
  local problems=0

  [ -d "$CORE_DIR" ] || { err "missing $CORE_DIR"; problems=$((problems+1)); }
  [ -f "$CONFIG" ] || { err "missing $CONFIG — run 'reins install'"; problems=$((problems+1)); }

  if [ -d "$REINS_HOME/.git" ]; then
    log "⚠ ~/.reins/ appears to be a git repository. Run 'reins reinstall' to fix this."
  fi
  if [ -f "$CONFIG" ] && ! grep -q "^installed_version:" "$CONFIG" 2>/dev/null; then
    log "⚠ No version info found. Run 'reins update' to refresh."
  fi

  local configured_agents
  configured_agents="$(config_get_agents)"
  if [ -z "$configured_agents" ]; then
    err "no agents configured — run 'reins install'"; problems=$((problems+1))
  else
    while IFS= read -r agent; do
      [ -n "$agent" ] || continue
      local entry
      if entry="$(agent_bridge_target "$agent" 2>/dev/null)"; then
        local bridge="${entry%%:*}"; local rest="${entry#*:}"
        local native="${rest%%:*}"
        [ -f "$bridge" ] || { err "missing bridge file $bridge — run 'reins update'"; problems=$((problems+1)); }
        if [ -f "$native" ]; then
          grep -qF "REINS:BEGIN" "$native" || { err "$native is missing the REINS managed block — run 'reins update'"; problems=$((problems+1)); }
        else
          err "$native does not exist — run 'reins update'"; problems=$((problems+1))
        fi
      else
        err "unknown agent '$agent' in config"; problems=$((problems+1))
      fi
    done <<< "$configured_agents"
  fi

  while IFS= read -r adapter; do
    [ -n "$adapter" ] || continue
    local dir="$USER_DIR/adapters/$adapter"
    [ -d "$dir" ] || { err "adapter '$adapter' listed in config but missing at $dir"; problems=$((problems+1)); }
    [ -f "$dir/ADAPTER.md" ] || { err "adapter '$adapter' missing ADAPTER.md"; problems=$((problems+1)); }
  done < <(config_adapters)

  if [ "$problems" -eq 0 ]; then
    log "Everything looks good."
  else
    log ""
    log "$problems issue(s) found."
    return 1
  fi
}

cmd_uninstall() {
  print_banner
  log "Uninstalling REINS Method..."

  # Remove the managed block from every native config REINS may have wired
  unwire_all_agents

  # Remove REINS-managed skill symlinks from all agents that use skills/ directories
  for _skills_dir in \
      "$HOME/.claude/skills" \
      "$HOME/.copilot/skills" \
      "$HOME/.gemini/skills" \
      "$HOME/.codex/skills"; do
    if [ -d "$_skills_dir" ] && find "$_skills_dir" -maxdepth 1 -type l -name 'reins-*' -print -quit | grep -q .; then
      cleanup_skill_links "$_skills_dir"
      log "Removed REINS skill symlinks from $_skills_dir"
    fi
  done

  # Remove the /usr/local/bin/reins symlink, if it points into REINS_HOME
  local target_bin="/usr/local/bin/reins"
  if [ -L "$target_bin" ] && [ "$(readlink "$target_bin")" = "$REINS_HOME/bin/reins" ]; then
    rm -f "$target_bin"
    log "Removed $target_bin"
  fi

  # Remove the PATH export line from shell rc files
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    [ -f "$rc" ] || continue
    if grep -qF "$REINS_HOME/bin" "$rc" 2>/dev/null; then
      grep -vF "export PATH=\"$REINS_HOME/bin:\$PATH\"" "$rc" > "$rc.tmp" && mv "$rc.tmp" "$rc"
      log "Removed PATH export from $rc"
    fi
  done

  log ""
  log "REINS is unhooked from your AI agent and shell."
  log "$REINS_HOME still contains your data, including \$REINS_HOME/user/ (standards,"
  log "adapters, skills, project contexts, historic records)."
  read -r -p "Delete $REINS_HOME entirely, including user/? This cannot be undone. [y/N] " yn
  case "$yn" in
    [yY]*)
      # Offer to save the user's personalization (standards, skills, adapters,
      # config, project contexts, historic data) before deleting everything
      read -r -p "Save your personalizations (standards, skills, adapters, config, project contexts, historic data) before deleting? [y/N] " backup_yn
      case "$backup_yn" in
        [yY]*)
          read -r -p "Directory to save them to: " backup_dir
          if [ -n "$backup_dir" ]; then
            mkdir -p "$backup_dir"
            cp -R "$USER_DIR" "$backup_dir/"
            log "Copied $USER_DIR to $backup_dir/$(basename "$USER_DIR")"
          else
            log "No directory given — skipping backup."
          fi
          ;;
      esac
      rm -rf "$REINS_HOME"
      log "Removed $REINS_HOME"
      ;;
    *)
      log "Left $REINS_HOME in place."
      ;;
  esac
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
REINS Method CLI

Usage:
  reins install              First-time setup (interactive wizard)
  reins install --non-interactive --agent=<id> [--agent=<id> ...]
                              [--standards=yes|no] [--historic=on|off]
                              [--adapter=<path>] [--language=<lang>]
                              [--doc-language=<lang>]
                             Non-interactive setup, driven by flags
                             (used by `npx reins-method install`)
  reins update                Pull latest core, regenerate agent bridge files
  reins new-adapter <name>    Scaffold a new adapter pack
  reins new-skill <name>      Scaffold a new skill
  reins sync                  Regenerate agent bridges + skill registration (no git pull)
  reins agents                Update which AI agents you use and re-wire
  reins edit <target>         Open a user config file/folder in \$EDITOR (standards|adapters|skills|historic|config)
  reins link-agents           Wire any newly-installed AI agents into existing bridges
  reins historic on|off       Enable/disable historic mode
  reins status                Show installed version, agent, adapters, historic mode
  reins graphify              Run graphify and store output in ~/.reins (not the repo)
  reins doctor                Validate the installation
  reins uninstall             Unhook REINS from your agent/shell, optionally delete ~/.reins
EOF
}

main() {
  local cmd="${1:-}"
  [ -n "$cmd" ] && shift || true
  case "$cmd" in
    install)     cmd_install "$@" ;;
    update)      cmd_update "$@" ;;
    new-adapter) cmd_new_adapter "$@" ;;
    new-skill)   cmd_new_skill "$@" ;;
    sync)        cmd_sync "$@" ;;
    agents)      cmd_agents "$@" ;;
    agents-set)  cmd_agents_set "$@" ;;
    edit)        cmd_edit "$@" ;;
    link-agents) cmd_link_agents "$@" ;;
    historic)    cmd_historic "$@" ;;
    status)      cmd_status "$@" ;;
    graphify)    cmd_graphify "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    uninstall)   cmd_uninstall "$@" ;;
    -h|--help|help|"") usage ;;
    *) err "unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
